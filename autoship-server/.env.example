PORT=
MONGO_URI=
MONGO_DB_NAME=
JWT_SECRET=
MONGO_DB_COLLECTION=
JWT_EXPIRATION=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:5000/auth/github/callback
GITHUB_REDIRECT_URI= http://localhost:5000/github/callback

# Base domain used to build dynamic-project subdomains (e.g. autoship.site)
DOMAIN=

# ──────────────────────────────────────────────────────────────────────────
# Cloud provider selector: "aws" (default) or "azure".
# Only the variables for the selected provider need to be filled in.
# ──────────────────────────────────────────────────────────────────────────
CLOUD_PROVIDER=aws

# ── AWS (CLOUD_PROVIDER=aws) ──────────────────────────────────────────────
# Static hosting -> S3 ; dynamic container ports -> EC2 security group.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
EC2_SECURITY_GROUP_ID=sg-xxxxxxxx
EC2_PUBLIC_IP=

# ── Azure (CLOUD_PROVIDER=azure) ──────────────────────────────────────────
# Static hosting -> Blob Storage. Required:
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
# Optional: container to upload into (default "$web" = static-website container)
AZURE_BLOB_CONTAINER=
# Optional: base URL for returned links. Leave blank to use the raw blob URL
# (https://<account>.blob.core.windows.net/<container>). Set this to your
# static-website endpoint (https://<account>.z##.web.core.windows.net) if you
# enabled "Static website" on the storage account.
AZURE_PUBLIC_BASE_URL=

# Dynamic container ports -> Network Security Group. Required only for dynamic
# projects:
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_NSG_NAME=
# Service-principal auth for the NSG client (or use a VM managed identity and
# leave these blank):
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
